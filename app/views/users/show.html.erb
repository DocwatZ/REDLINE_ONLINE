<% content_for :title, @user.display_name %>

<div style="max-width:32rem;padding:2rem;overflow-y:auto;flex:1">
  <div style="display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:2rem">
    <div class="avatar avatar-xl"
         style="background-color:<%= @user.avatar_color %>"
         aria-hidden="true">
      <%= @user.initials %>
    </div>
    <div style="flex:1;min-width:0">
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--rl-text-primary)">
        <%= @user.display_name %>
      </h1>
      <div style="display:flex;align-items:center;gap:.5rem;margin-top:.25rem">
        <span class="status-dot status-<%= @user.status %>"
              aria-hidden="true"></span>
        <span style="font-size:.875rem;color:var(--rl-text-muted);text-transform:capitalize">
          <%= @user.status %>
        </span>
      </div>
      <% if @user.bio.present? %>
        <p style="font-size:.875rem;color:var(--rl-text-secondary);margin-top:.75rem;line-height:1.6">
          <%= @user.bio %>
        </p>
      <% end %>
    </div>
  </div>

  <% if @user != current_user %>
    <%= link_to "Send Message", user_direct_messages_path(@user),
          class: "btn btn-primary",
          aria: { label: "Send direct message to #{@user.display_name}" } %>
  <% end %>
</div>
